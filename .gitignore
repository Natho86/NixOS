# Plaintext or local-only secret material
secrets/*.plain.yaml
secrets/*.decrypted.yaml
secrets/*.env
secrets/age-key.txt

# Encrypted SOPS files are intended to be committed
!secrets/secrets.yaml
!.sops.yaml

# Age keys (never commit these!)
*.txt
keys.txt

# NixOS result symlinks
result
result-*

# Direnv
.direnv/
.envrc

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Claude Code personal commands
.claude/commands/

# Local testing
test-vm/

# Machine-specific NixOS hardware configs
hosts/*/hardware-configuration.nix

